# Copy to .env in EasyPanel → App → Environment
# Database service name = hostname inside EasyPanel (e.g. mysql, postgres)

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laragcc
DB_USERNAME=laragcc
DB_PASSWORD=change_me

# Laravel-style URL (optional until backend is added)
APP_URL=https://your-domain.com
